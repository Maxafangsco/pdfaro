# ── Analytics ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# ── Supabase (optional) ───────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ── Contact form email (Resend) ───────────────────────────────────────────────
# Get your API key at https://resend.com/api-keys
# RESEND_API_KEY must NEVER be prefixed with NEXT_PUBLIC_ — it must stay server-side only.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx

# Email address that receives contact-form submissions.
CONTACT_TO_EMAIL=your-inbox@example.com

# Sender address shown in the "From:" field.
# ⚠️  Gmail / Yahoo / Hotmail addresses do NOT work — Resend only sends from domains you own.
# Development shortcut (no domain setup needed, delivers only to your Resend account email):
#   CONTACT_FROM_EMAIL=onboarding@resend.dev
# Production (after verifying your domain in Resend — see docs/PDFARO_CONTACT_EMAIL_SETUP.md):
CONTACT_FROM_EMAIL=contact@send.yourdomain.com

# ── Misc ─────────────────────────────────────────────────────────────────────
password=
projectName=
